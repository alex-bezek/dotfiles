# Ghostty config — theme managed by themes/switch-theme.sh
# https://ghostty.org/docs/config

theme = Synthwave Everything

font-family = JetBrainsMono Nerd Font
font-size = 13

window-padding-x = 8
window-padding-y = 8
background-opacity = 0.97

# Make native Ghostty splits easier to distinguish at a glance.
split-divider-color = #5a6bff
unfocused-split-opacity = 1

# Shell integration
# Keep shell integration on so Ghostty can detect running processes (smart close prompts,
# jump-to-prompt, etc.). Only disable prompt-redraw, which can interfere with scrollback
# behavior on macOS, especially when working over SSH with large command output.
shell-integration-features = no-sudo,no-title

# Bell — show 🔔 on background tabs that fire a bell, plus dock badge.
# Combined with shell precmd/preexec hooks this gives a "process finished" signal.
bell-features = title,attention

# Tabs / windows
macos-titlebar-style = tabs
window-title-font-family = JetBrainsMono Nerd Font
keybind = global:f1=toggle_quick_terminal
keybind = super+shift+s=write_scrollback_file:open

# Quick terminal on the current macOS Space/screen.
quick-terminal-position = center
quick-terminal-size = 100%,100%
quick-terminal-animation-duration = 0.08
quick-terminal-space-behavior = move
quick-terminal-autohide = true

# Clipboard
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true

# Mouse
mouse-scroll-multiplier = 3
mouse-hide-while-typing = true

# Cursor
cursor-style = bar
cursor-style-blink = true

# Scrollback
# Keep enough terminal history to inspect large command output without relying on a pager.
# Ghostty measures this in bytes, not lines.
scrollback-limit = 50000000

# Auto-update
# TODO: Switch back to `stable` once Ghostty 1.3.2 stable is released.
# Using `tip` to pick up the scrollback-limit bug fix merged after 1.3.1.
# Tracked: https://github.com/ghostty-org/ghostty/discussions/11846
auto-update-channel = tip
